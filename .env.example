# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Google Gemini API Key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas — free tier, works on Vercel serverless
# 1. Go to https://cloud.mongodb.com → create free cluster
# 2. Database Access → create user with readWrite role
# 3. Network Access → Allow access from anywhere (0.0.0.0/0)
# 4. Connect → Drivers → copy the connection string, replace <password>
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/resumon?retryWrites=true&w=majority&appName=Cluster0
